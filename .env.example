# =============================================================================
# VisionForge — copy to .env and fill in your values
# =============================================================================

# --- Database (required) ---
# Atlas: prefer the "Standard" connection string if signup/API returns 500 and logs querySrv ECONNREFUSED
MONGODB_URI=mongodb://<username>:<password>@<shard-host>.mongodb.net:27017/visionforge?ssl=true&authSource=admin&directConnection=true
# Or SRV (works when Node can resolve DNS SRV records):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/visionforge

# --- Auth: email / password sign-in (required) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-long-random-string-here
# NextAuth v5 also reads AUTH_SECRET if set (can match NEXTAUTH_SECRET)
AUTH_SECRET=

# --- AI: text, agents, RAG, resume screener (required) ---
GEMINI_API_KEY=your-gemini-api-key-from-aistudio.google.com
GROQ_API_KEY=your-groq-api-key-from-console.groq.com

# --- AI: image generation — fal.ai primary (recommended) ---
FAL_API_KEY=your-fal-api-key-from-fal.ai

# --- AI: knowledge RAG embeddings + image fallback (recommended) ---
# Required for document upload when Gemini embedding quota is exceeded
HUGGINGFACE_API_KEY=your-hf-token-with-inference-providers-permission
# POLLINATIONS_API_KEY=
# STABLE_HORDE_API_KEY=

# --- OAuth (not used — app uses email/password login) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
